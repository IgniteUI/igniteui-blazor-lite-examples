@code {
    public IgbNavDrawer DrawerRef { get; set; } = default!;
    bool IsOpen { get; set; } = true;

    public void Toggle()
    {
        IsOpen = !IsOpen;
        StateHasChanged();
    }

    void Navigate(string path)
    {
        Navigation.NavigateTo(path);
    }
}

