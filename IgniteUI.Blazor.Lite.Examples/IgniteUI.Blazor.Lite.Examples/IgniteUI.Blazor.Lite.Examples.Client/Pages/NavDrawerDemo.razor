@page "/navdrawer"

<PageTitle>Navigation Drawer Demo</PageTitle>

<h3>Navigation Drawer</h3>

<p>The application sidebar uses an <code>IgbNavDrawer</code> component. Use the button below to toggle it.</p>

<IgbButton Variant="@ButtonVariant.Contained" @onclick="ToggleDrawer">Toggle App Navigation</IgbButton>

@code {
    [CascadingParameter]
    public NavMenu? NavMenuRef { get; set; }

    void ToggleDrawer() => NavMenuRef?.Toggle();
}
