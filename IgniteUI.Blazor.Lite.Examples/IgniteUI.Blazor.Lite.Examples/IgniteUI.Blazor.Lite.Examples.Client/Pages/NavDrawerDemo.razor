@page "/navdrawer"
@rendermode InteractiveWebAssembly

<PageTitle>Navigation Drawer Demo</PageTitle>

<h3>Navigation Drawer</h3>

<IgbButton Variant="@ButtonVariant.Contained" @onclick="ToggleDrawer">Toggle Drawer</IgbButton>

<IgbNavDrawer @ref="DrawerRef" Open="true">
    <IgbNavDrawerHeaderItem>Navigation</IgbNavDrawerHeaderItem>
    <IgbNavDrawerItem>
        <span slot="content">Home</span>
    </IgbNavDrawerItem>
    <IgbNavDrawerItem>
        <span slot="content">Search</span>
    </IgbNavDrawerItem>
    <IgbNavDrawerItem>
        <span slot="content">Settings</span>
    </IgbNavDrawerItem>
</IgbNavDrawer>

@code {
    IgbNavDrawer DrawerRef { get; set; } = default!;
    void ToggleDrawer() => DrawerRef.Toggle();
}
