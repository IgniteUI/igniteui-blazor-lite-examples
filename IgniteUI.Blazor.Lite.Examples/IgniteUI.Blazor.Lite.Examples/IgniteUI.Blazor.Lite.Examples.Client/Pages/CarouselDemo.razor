@page "/carousel"
@rendermode InteractiveWebAssembly

<PageTitle>Carousel Demo</PageTitle>

<h3>Carousel</h3>

<IgbCarousel style="height: 300px;">
    <IgbCarouselSlide Active="true">
        <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #e3f2fd;">
            <h2>Slide 1</h2>
        </div>
    </IgbCarouselSlide>
    <IgbCarouselSlide>
        <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f3e5f5;">
            <h2>Slide 2</h2>
        </div>
    </IgbCarouselSlide>
    <IgbCarouselSlide>
        <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #e8f5e9;">
            <h2>Slide 3</h2>
        </div>
    </IgbCarouselSlide>
</IgbCarousel>
